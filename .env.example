# .env.example - generated with dotenvx

#/-------------------[DOTENV_PUBLIC_KEY]--------------------/
#/            public-key encryption for .env files          /
#/       [how it works](https://dotenvx.com/encryption)     /
#/----------------------------------------------------------/
DOTENV_PUBLIC_KEY_CI=""

# .env.ci
#/-------------------[DOTENV_PUBLIC_KEY]--------------------/
#/            public-key encryption for .env files          /
#/       [how it works](https://dotenvx.com/encryption)     /
#/----------------------------------------------------------/
DOTENV_PUBLIC_KEY_LOCAL=""

# .env.local
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_MEASUREMENT_ID=
FIREBASE_BUCKET=
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=""


# DocuSign Configuration
# Get these values from https://admindemo.docusign.com/ (developer account)

# Your DocuSign Integration Key (Client ID) from the Apps and Keys page
DOCUSIGN_INTEGRATION_KEY=

# Your DocuSign User ID (API Username) - found in Apps and Keys
DOCUSIGN_USER_ID=

# Your DocuSign Account ID - found in Admin > API and Keys
# NOTE: This is optional - the account ID is now automatically retrieved via getUserInfo()
# DOCUSIGN_ACCOUNT_ID=7051b323-9dd6-4cca-b0a6-07b2012da4e5

# DocuSign API Base Path
# Use demo for development: https://demo.docusign.net
# Use production: https://na3.docusign.net (or your region)
# NOTE: Do NOT include /restapi suffix - it's added automatically
DOCUSIGN_BASE_PATH=

# Your RSA Private Key for JWT authentication (generate in Apps and Keys)
DOCUSIGN_PRIVATE_KEY=""