# DocuSign Configuration
# Get these values from https://admindemo.docusign.com/ (developer account)

# Your DocuSign Integration Key (Client ID) from the Apps and Keys page
DOCUSIGN_INTEGRATION_KEY=

# Your DocuSign User ID (API Username) - found in Apps and Keys
DOCUSIGN_USER_ID=

# Your DocuSign Account ID - found in Admin > API and Keys
DOCUSIGN_ACCOUNT_ID=

# Your RSA Private Key for JWT authentication (generate in Apps and Keys)
# Format: Replace all \n with actual newlines, or keep as single line with \n escaped
DOCUSIGN_PRIVATE_KEY=

# DocuSign API Base Path
# Use demo for development: https://demo.docusign.net/restapi
# Use production: https://na3.docusign.net/restapi (or your region)
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi

# Firebase Configuration
# Add your Firebase project configuration here
# (existing keys from your current .env.local)
